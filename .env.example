# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Модель агента. Sonnet рекомендуется (качество RU/KZ). Можно сменить на Haiku для экономии.
AGENT_MODEL=claude-sonnet-4-5

# --- Instagram / Meta ---
# Любая строка, которую ты сам придумаешь — её же вставишь в настройках вебхука в Meta.
IG_VERIFY_TOKEN=kazzhol_verify_123
# Долгоживущий access token Instagram-аккаунта (получаешь при OAuth-подключении).
IG_ACCESS_TOKEN=
# App Secret из настроек Meta App (для проверки подписи вебхуков).
IG_APP_SECRET=
# ID Instagram Business аккаунта (опционально, для исходящих).
IG_ACCOUNT_ID=

# --- База данных ---
# Прод: Postgres (напр. Neon). Локально оставь пустым — будет SQLite-файл.
# Пример: postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- App ---
# Рабочие часы менеджера (для пометки "после рабочего дня"). 24ч формат, Asia/Almaty.
WORK_HOURS_START=9
WORK_HOURS_END=20
